# Supabase project URL (from Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (from Project Settings > API > service_role)
# Keep this secret – it bypasses Row Level Security
SUPABASE_SERVICE_KEY=your-service-role-key

# Port for the HTTP server (SSE + health)
PORT=3000

# Optional: secret used to validate incoming Workato webhook requests
WORKATO_WEBHOOK_SECRET=your-webhook-secret
